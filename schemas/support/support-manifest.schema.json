{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentapi-doctor:schema:support-manifest:v1",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "kind", "manifestStatus", "d30Catalog", "cells"],
  "properties": {
    "schemaVersion": {"const": "urn:agentapi-doctor:support-manifest:v1"},
    "kind": {"const": "SupportManifest"},
    "manifestStatus": {"enum": ["candidate", "approved"]},
    "d30Catalog": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^D30-[A-Z0-9-]+$"}, "additionalProperties": {"type": "string", "minLength": 1}},
    "cells": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/cell"}}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,160}$"},
    "cell": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "artifact", "tier", "maturityTarget", "versionPolicy", "platforms", "ciCadence", "releaseBlocking", "ownership", "updateSLA", "knownGapPolicy", "d30Criteria", "tierGates"],
      "properties": {
        "id": {"$ref": "#/$defs/name"},
        "artifact": {"type": "object", "additionalProperties": false, "required": ["kind", "name", "path"], "properties": {"kind": {"enum": ["ProtocolPack", "ConsumerCompatibilityProfile", "ExternalSuiteAdapter", "RuntimeMetadataAdapter"]}, "name": {"$ref": "#/$defs/name"}, "path": {"type": "string", "minLength": 1}}},
        "tier": {"enum": ["tier1", "tier2"]},
        "maturityTarget": {"enum": ["stable", "experimental"]},
        "versionPolicy": {"type": "object", "additionalProperties": false, "required": ["applicability", "selectors", "exactResolutionRequired"], "properties": {"applicability": {"enum": ["required", "not_applicable"]}, "selectors": {"type": "array", "uniqueItems": true, "items": {"enum": ["current", "previous", "candidate", "exact-experimental"]}}, "exactResolutionRequired": {"const": true}}},
        "platforms": {"type": "object", "additionalProperties": false, "required": ["os", "arch"], "properties": {"os": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["linux", "macos", "windows"]}}, "arch": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["amd64", "arm64"]}}}},
        "ciCadence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["pull_request", "nightly", "release"]}},
        "releaseBlocking": {"type": "boolean"},
        "ownership": {"type": "object", "additionalProperties": false, "required": ["primary", "backup"], "properties": {"primary": {"$ref": "#/$defs/owner"}, "backup": {"$ref": "#/$defs/owner"}}},
        "updateSLA": {"type": "object", "additionalProperties": false, "required": ["days", "clock"], "properties": {"days": {"type": "integer", "minimum": 1}, "clock": {"enum": ["upstream-stable-release", "upstream-stable-change"]}}},
        "knownGapPolicy": {"enum": ["tier1-no-unresolved-required", "tier2-publish-all-gaps"]},
        "d30Criteria": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^D30-[A-Z0-9-]+$"}},
        "tierGates": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["pending", "passed"]}}
      }
    },
    "owner": {"type": "object", "additionalProperties": false, "required": ["role", "status"], "properties": {"role": {"$ref": "#/$defs/name"}, "status": {"enum": ["pending-assignment", "assigned"]}}}
  }
}
