{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentapi-doctor:schema:pack-candidate-status:v1",
  "title": "AgentAPI Doctor non-publishable pack candidate status",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack", "protocol", "release_track", "status", "review_status", "claimed_tier", "publication", "independent_review", "real_sdk_validation", "live_provider_verified", "known_gaps"],
  "properties": {
    "schema_version": {"const": "urn:agentapi-doctor:pack-candidate-status:v1"},
    "pack": {"type": "string", "minLength": 3},
    "protocol": {"type": "string", "minLength": 3},
    "release_track": {"enum": ["core-candidate", "required-experimental"]},
    "status": {"const": "candidate"},
    "review_status": {"const": "pending_review"},
    "claimed_tier": {"const": "none"},
    "publication": {"const": "blocked_pending_review"},
    "independent_review": {"const": false},
    "real_sdk_validation": {"const": false},
    "live_provider_verified": {"const": false},
    "known_gaps": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
