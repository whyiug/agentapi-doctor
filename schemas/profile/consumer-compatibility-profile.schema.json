{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentapi-doctor:schema:consumer-profile:v1beta1",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "kind", "status", "metadata", "spec"],
  "properties": {
    "schemaVersion": {"const": "urn:agentapi-doctor:consumer-profile:v1beta1"},
    "kind": {"const": "ConsumerCompatibilityProfile"},
    "status": {"const": "candidate"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "spec": {"$ref": "#/$defs/spec"}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$"},
    "metadata": {"type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": {"id": {"$ref": "#/$defs/name"}, "version": {"type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$"}}},
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["consumer", "driverRef", "protocolPacks", "apiTypes", "requiredCapabilities", "sandbox", "supportGate"],
      "properties": {
        "consumer": {"type": "object", "additionalProperties": false, "required": ["name", "category", "upstreamVersionResolution", "exactVersions"], "properties": {"name": {"type": "string", "minLength": 1}, "category": {"enum": ["sdk", "agent-client"]}, "upstreamVersionResolution": {"enum": ["unresolved", "resolved"]}, "exactVersions": {"type": "array", "items": {"type": "string"}}}},
        "driverRef": {"type": "string", "pattern": "^runners/(raw|python|node|agent)/driver\\.yaml$"},
        "protocolPacks": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
        "apiTypes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
        "forbiddenFallbacks": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
        "excludedApiTypes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
        "requiredCapabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
        "sandbox": {"type": "object", "additionalProperties": false, "required": ["temporaryHome", "network", "ambientCredentials"], "properties": {"temporaryHome": {"const": true}, "temporaryGitRepo": {"type": "boolean"}, "network": {"const": "recorder-only"}, "ambientCredentials": {"const": false}, "syntheticToolsOnly": {"type": "boolean"}}},
        "supportGate": {"type": "object", "additionalProperties": false, "required": ["status", "reason", "evidenceRefs"], "properties": {"status": {"enum": ["pending", "passed"]}, "reason": {"type": "string", "minLength": 1}, "evidenceRefs": {"type": "array", "items": {"type": "string"}}}}
      }
    }
  }
}
