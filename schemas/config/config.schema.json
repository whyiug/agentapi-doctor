{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentapi-doctor:schema:config:v1beta2",
  "title": "AgentAPI Doctor project configuration",
  "type": "object",
  "required": ["apiVersion", "targets"],
  "properties": {
    "apiVersion": {"const": "urn:agentapi-doctor:config:v1beta2"},
    "targets": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
      "additionalProperties": {"$ref": "#/$defs/target"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "secretRef": {
      "type": "string",
      "oneOf": [
        {"pattern": "^env://[^/\\\\\\r\\n\\x00]+$"},
        {"pattern": "^(keyring|file|exec)://[^\\r\\n\\x00]+$"}
      ]
    },
    "target": {
      "type": "object",
      "required": ["baseURL", "protocol", "model"],
      "properties": {
        "baseURL": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://[^/?#@]+",
          "allOf": [
            {"not": {"pattern": "^https?://[^/?#]*@"}},
            {"not": {"pattern": "[?#]"}}
          ]
        },
        "protocol": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "auth": {
          "type": "object",
          "required": ["type", "token"],
          "properties": {
            "type": {"enum": ["bearer", "header"]},
            "token": {
              "type": "object",
              "required": ["ref"],
              "properties": {"ref": {"$ref": "#/$defs/secretRef"}},
              "additionalProperties": false
            },
            "header": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {"properties": {"type": {"const": "header"}}, "required": ["type"]},
              "then": {"required": ["header"]}
            }
          ]
        },
        "metadata": {"type": "object", "additionalProperties": {"type": "string"}}
      },
      "additionalProperties": false
    }
  }
}
