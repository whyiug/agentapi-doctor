{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentapi-doctor:schema:cli-result:v1alpha1",
  "title": "AgentAPI Doctor CLI result envelope",
  "description": "The machine-readable envelope emitted by Doctor commands that do not write a report renderer directly.",
  "type": "object",
  "required": ["schema_version", "status", "primary_exit_code", "conditions"],
  "properties": {
    "schema_version": {"const": "urn:agentapi-doctor:cli-result:v1alpha1"},
    "status": {"enum": ["pass", "fail", "error"]},
    "primary_exit_code": {"enum": [0, 1, 2, 3, 4, 5, 6, 130]},
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {"type": "string", "pattern": ".*\\S.*"},
          "message": {"type": "string", "pattern": ".*\\S.*"}
        },
        "additionalProperties": false
      }
    },
    "data": true
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "pass"}}, "required": ["status"]},
      "then": {"properties": {"primary_exit_code": {"const": 0}}}
    },
    {
      "if": {"properties": {"status": {"enum": ["fail", "error"]}}, "required": ["status"]},
      "then": {"not": {"properties": {"primary_exit_code": {"const": 0}}, "required": ["primary_exit_code"]}}
    }
  ]
}
